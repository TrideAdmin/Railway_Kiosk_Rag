# ═══════════════════════════════════════════════════
#  Railway Kiosk RAG — Environment Variables
# ═══════════════════════════════════════════════════

# ── Gemini (Google AI) ───────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Pinecone (Vector DB) ─────────────────────────
# Get from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=railway-kiosk

# ── Sarvam AI (STT/TTS) ──────────────────────────
# Get from: https://app.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# ── IRCTC / Live Train API (optional) ────────────
# Get from: https://rapidapi.com/search/irctc
IRCTC_API_KEY=your_irctc_api_key_here

# ── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── AWS / GCP (for deployment) ───────────────────
# AWS_REGION=ap-south-1
# GCP_PROJECT=your-project-id
